# ── Engine core ──────────────────────────────────────
SEQUENCER_PRIVATE_KEY=0x_your_sequencer_private_key_here
PINATA_API_KEY=your_pinata_api_key_here
# ── EIP-4337 Bundler (Pimlico) ───────────────────────
# Required for UserOp submission (bond deposits via AgentAccount)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
PRIVATE_KEY=0x_your_32_byte_private_key_here
PIMLICO_BUNDLER_URL=https://api.pimlico.io/v2/84532/rpc?apikey=YOUR_PIMLICO_API_KEY

# Optional bundler fallbacks (comma-separated)
BUNDLER_URL_FALLBACKS=

# Optional: Pimlico's own paymaster (we use our AgentPaymaster, so usually not needed)
PIMLICO_PAYMASTER_URL=
PIMLICO_PAYMASTER_URL_FALLBACKS=

# Optional: demo destination and value
DESTINATION=
TX_VALUE_WEI=
REQUEST_TIMEOUT_MS=15000