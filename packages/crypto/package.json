{
  "name": "@agent-auction/crypto",
  "version": "0.1.0",
  "description": "Cryptographic primitives for agent-auction: Poseidon hashing, ZK proof verification, EIP-712, nullifiers",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./poseidon-chain": {
      "import": "./dist/poseidon-chain.js",
      "types": "./dist/poseidon-chain.d.ts"
    },
    "./replay-bundle": {
      "import": "./dist/replay-bundle.js",
      "types": "./dist/replay-bundle.d.ts"
    },
    "./signal-indices": {
      "import": "./dist/signal-indices.js",
      "types": "./dist/signal-indices.d.ts"
    },
    "./x402-access": {
      "import": "./dist/x402-access.js",
      "types": "./dist/x402-access.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "poseidon-lite": "^0.3.0",
    "snarkjs": "^0.7.5",
    "ethers": "^6.13.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
