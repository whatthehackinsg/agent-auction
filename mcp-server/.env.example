# Default local startup file:
# 1. copy this file to .env.agentkit.local
# 2. run `npm run dev`
# The MCP server will auto-load .env.agentkit.local when present.

# Wallet backend selection
MCP_WALLET_BACKEND=agentkit

# Engine read mode:
# - x402-buyer   = supported default, MCP pays public discovery/detail gates with the same wallet
# - admin-bypass = developer/debug only, requires ENGINE_ADMIN_KEY
MCP_ENGINE_READ_MODE=x402-buyer

# Supported: AgentKit + CDP Server Wallet (preferred write path)
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_WALLET_SECRET=
CDP_WALLET_ADDRESS=
CDP_NETWORK_ID=base-sepolia

# Advanced bridge: raw private key path
AGENT_PRIVATE_KEY=0x...

# Required for most write flows after registration / attach
AGENT_ID=1
AGENT_STATE_FILE=./agent-1.json

# Required for on-chain MCP tools
BASE_SEPOLIA_RPC=https://sepolia.base.org

# Optional
AGENT_STATE_DIR=./agents
BOND_FUNDING_PRIVATE_KEY=
ENGINE_URL=https://auction-engine.zengyuzhi2002-efc.workers.dev
# Debug-only: bypasses engine x402 discovery/detail gates when MCP_ENGINE_READ_MODE=admin-bypass
ENGINE_ADMIN_KEY=
MCP_PORT=3100
