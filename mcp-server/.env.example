# Required for write tools
AGENT_PRIVATE_KEY=0x...          # 64-char hex private key for MCP signing and on-chain writes

# Required for most write flows after registration
AGENT_ID=1                       # Default numeric ERC-8004 agent ID (register_identity mints a new one)
AGENT_STATE_FILE=./agent-1.json  # Path to agent-N.json for JOIN/BID proof generation

# Required for on-chain MCP tools
BASE_SEPOLIA_RPC=https://sepolia.base.org  # Base Sepolia RPC for register_identity, deposit_bond, refunds, withdrawals, and registry-root reads

# Optional
AGENT_STATE_DIR=./agents                # Default directory for per-agent state files created by register_identity
BOND_FUNDING_PRIVATE_KEY=               # Optional alternate funding signer for deposit_bond; must still own the target agentId
ENGINE_URL=http://localhost:8787
ENGINE_ADMIN_KEY=                       # Bypasses x402 discovery gates
MCP_PORT=3100                           # HTTP port for Streamable HTTP transport
