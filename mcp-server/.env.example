# Wallet backend selection
MCP_WALLET_BACKEND=auto          # auto (supported AgentKit/CDP wins), agentkit, or raw-key

# Supported: AgentKit + CDP Server Wallet (preferred write path)
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_WALLET_SECRET=
CDP_WALLET_ADDRESS=              # Existing Base Sepolia owner wallet address to reuse
CDP_NETWORK_ID=base-sepolia

# Advanced bridge: raw private key path
AGENT_PRIVATE_KEY=0x...          # 64-char hex private key for MCP signing and on-chain writes

# Required for most write flows after registration / attach
AGENT_ID=1                       # Default numeric ERC-8004 agent ID (register_identity can mint or attach)
AGENT_STATE_FILE=./agent-1.json  # Path to agent-N.json for JOIN/BID proof generation or attachExisting

# Required for on-chain MCP tools
BASE_SEPOLIA_RPC=https://sepolia.base.org  # Base Sepolia RPC for register_identity, deposit_bond, refunds, withdrawals, and registry-root reads

# Optional
AGENT_STATE_DIR=./agents                # Default directory for generated agent-N.json files
BOND_FUNDING_PRIVATE_KEY=               # Raw-key bridge only: optional alternate funding signer; must still own the target agentId
ENGINE_URL=http://localhost:8787
ENGINE_ADMIN_KEY=                       # Bypasses x402 discovery gates
MCP_PORT=3100                           # HTTP port for Streamable HTTP transport
