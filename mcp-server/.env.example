# Required
AGENT_PRIVATE_KEY=0x...        # 64-char hex private key for EIP-712 signing
AGENT_ID=1                     # Numeric ERC-8004 agent ID
AGENT_STATE_FILE=./agent-1.json  # Path to agent-N.json — needed for mandatory ZK proof generation
BASE_SEPOLIA_RPC=https://sepolia.base.org  # RPC endpoint for Base Sepolia — needed for on-chain identity verification and proof generation

# Optional
ENGINE_URL=http://localhost:8787
ENGINE_ADMIN_KEY=              # Bypasses x402 discovery gates
MCP_PORT=3100                  # HTTP port for Streamable HTTP transport
